# ============================================================
# API Center — Environment Variables (Dynamic Service Registry)
# Copy this file to .env and fill in the values
# ============================================================

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- Descope (Authentication & Authorization) ----
# Descope provides Identity & Access Management (IAM).
# It validates JWT tokens, issues M2M service tokens, and manages permissions.
# Get your credentials at https://app.descope.com
DESCOPE_PROJECT_ID=your_project_id
DESCOPE_MANAGEMENT_KEY=your_management_key

# ---- Kafka (Event Streaming) ----
# Kafka handles asynchronous inter-service communication and audit logging.
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=api-center
KAFKA_GROUP_ID=api-center-group

# ---- Platform Admin Secret ----
# Protects the /api/v1/registry/register endpoint.
# Only platform administrators and CI/CD pipelines should know this secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLATFORM_ADMIN_SECRET=your_platform_admin_secret_here

# ---- Redis (Split Responsibilities) ----
# Two separate Redis instances for isolation and performance.
# REDIS_RATE_LIMIT_URL — Dedicated to ThrottlerGuard / rate limiting
# REDIS_CACHE_URL      — Registry persistence + token caching
REDIS_RATE_LIMIT_URL=redis://localhost:6380
REDIS_CACHE_URL=redis://localhost:6381

# ---- Supabase (optional — persistent registry storage) ----
# If not set, the registry operates in memory-only mode.
# Services must re-register after restart.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- AWS Secrets Manager (optional — runtime secrets) ----
# If AWS_SECRET_NAME is set, secrets are loaded from AWS Secrets Manager
# at boot time. Falls back to process.env if not configured (local dev).
# AWS_SECRET_NAME=api-center/production
# AWS_REGION=us-east-1

# ---- OpenTelemetry / Jaeger (Distributed Tracing) ----
# Traces are exported to Jaeger for distributed request tracing.
# JAEGER_ENDPOINT=http://localhost:14268/api/traces
# OTEL_SERVICE_NAME=api-center

# ---- Service Secrets ----
# SHA-256 hashed secrets used by services to authenticate with the API Center.
# Env var pattern: TRIBE_SECRET_{SERVICE_ID_UPPERCASED}
# Hyphens in serviceId become underscores (e.g., 'my-service' → TRIBE_SECRET_MY_SERVICE)
# In production, use a secrets manager (AWS Secrets Manager / HashiCorp Vault)
TRIBE_SECRET_CAMPUSONE=hashed_secret_here
TRIBE_SECRET_ANALYTICS_SERVICE=hashed_secret_here
TRIBE_SECRET_PAYMENT_SERVICE=hashed_secret_here
TRIBE_SECRET_NOTIFICATION_SERVICE=hashed_secret_here

# ---- External APIs ----
# Credentials for third-party APIs proxied through the API Center.
# Services NEVER access external APIs directly — the API Center holds all keys.

# Geolocation API (e.g., Google Maps Geocoding, Mapbox, etc.)
EXT_GEOLOCATION_URL=https://maps.googleapis.com/maps/api
EXT_GEOLOCATION_API_KEY=your_geolocation_api_key

# Geofencing API (e.g., Radar.io, HERE, etc.)
EXT_GEOFENCING_URL=https://api.radar.io/v1
EXT_GEOFENCING_API_KEY=your_geofencing_api_key

# Payment Gateway
EXT_PAYMENT_URL=https://api.payment-provider.com
EXT_PAYMENT_TOKEN=your_payment_token

# SMS Service
EXT_SMS_URL=https://api.sms-provider.com
EXT_SMS_API_KEY=your_sms_key

# Email Service
EXT_EMAIL_URL=https://api.email-provider.com
EXT_EMAIL_TOKEN=your_email_token

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
